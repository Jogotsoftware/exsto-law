{
  "name": "@exsto/worker-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./liveness": {
      "types": "./dist/liveness.d.ts",
      "import": "./dist/liveness.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "@exsto/shared": "workspace:*",
    "@exsto/substrate": "workspace:*"
  }
}
