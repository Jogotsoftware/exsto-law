{
  "name": "@exsto/rest-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node ./dist/index.js",
    "gen:docs": "node ./scripts/gen-docs.mjs",
    "create-key": "node ./scripts/create-api-key.mjs",
    "parity": "node ./scripts/parity.mjs"
  },
  "dependencies": {
    "@exsto/mcp-tools": "workspace:*",
    "@exsto/shared": "workspace:*",
    "@exsto/substrate": "workspace:*"
  }
}
