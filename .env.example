# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored so secrets stay out of version control.

# -----------------------------------------------------------------------------
# Supabase — exsto-law uses the "exsto-law" project (jfcarzprfpoztxuqykoe, us-east-1)
# -----------------------------------------------------------------------------
# Project URL                      → Settings ▸ API ▸ Project URL
SUPABASE_URL=https://jfcarzprfpoztxuqykoe.supabase.co
# Anon public key                  → Settings ▸ API ▸ Project API keys ▸ anon
SUPABASE_ANON_KEY=
# Service role key                 → Settings ▸ API ▸ Project API keys ▸ service_role
SUPABASE_SERVICE_ROLE_KEY=
# Browser-exposed Supabase config for CLIENT PORTAL sign-in (email + password via
# Supabase Auth). Both are PUBLIC by design (the anon key is safe in the browser;
# RLS + the portal session enforce access). Required for portal sign-in.
#   • Enable email/password: Supabase ▸ Authentication ▸ Providers ▸ Email
#   • Add redirect URL: <your site>/portal/login  (Auth ▸ URL Configuration —
#     used by the sign-up confirmation link)
#   • SECURITY-CRITICAL: turn ON "Confirm email" (Auth ▸ Providers ▸ Email). The
#     portal trusts Supabase's email_confirmed_at as proof of email control; with
#     confirmation OFF Supabase auto-confirms sign-ups, which would let anyone
#     create an account as another client's email. This is ENFORCED in code: the
#     bridge checks GoTrue's /auth/v1/settings and FAILS CLOSED (portal sign-in
#     returns 503) if auto-confirm is on, so a misconfigured project announces
#     itself loudly instead of silently allowing takeover. Keep this ON.
NEXT_PUBLIC_SUPABASE_URL=https://jfcarzprfpoztxuqykoe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Pooler connection string         → Settings ▸ Database ▸ Connection string
#                                   ▸ "Session" or "Transaction" pooler URI
# The password lives only in the dashboard; paste the full URL here with the
# password substituted in.
#
# CRITICAL (ADR 0037): the `postgres` role shown here BYPASSES row-level security.
# Use it ONLY for migrations/seed (pnpm migrate / pnpm seed). Application + worker
# code MUST connect as a NON-owner role (Supabase `authenticated`/`anon` via the
# API, or a dedicated app login role) or tenant isolation is silently inactive.
# Verify with: SUBSTRATE_TEST_DATABASE_URL=... pnpm test:invariants
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Connection used by the invariant test suite (tests/invariants). Point it at a
# DISPOSABLE Supabase project (never production). Without it, the DB-gated
# invariant tests skip. CI sets this from a secret; locally you can reuse a dev URL.
SUBSTRATE_TEST_DATABASE_URL=

# -----------------------------------------------------------------------------
# Anthropic — used by the legal vertical drafting adapter
# PLATFORM DEFAULT only: a key connected in Settings -> Integrations (stored in
# Vault) takes precedence per tenant. Same for GRANOLA_* below. Keys pasted in
# the UI never live in env or in any table column.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Optional: pin the drafting model. Defaults to claude-sonnet-4-6. The
# preflight script uses claude-haiku-4-5-20251001 for its API ping regardless.
LEGAL_DRAFTING_MODEL=

# -----------------------------------------------------------------------------
# Granola (consultation transcripts) — per-attorney OAuth + MCP, connected in
# Settings -> Integrations. ALL OPTIONAL: the OAuth client registers dynamically
# (DCR, a public PKCE client — no secret) and the redirect URI is DERIVED from the
# base URL (NEXT_PUBLIC_BASE_URL / URL, default https://exstolaw.netlify.app), so
# the connect flow works with nothing set here. (Needs OAUTH_STATE_SECRET below.)
# -----------------------------------------------------------------------------
# Override the derived callback (default: <base>/api/auth/granola/callback).
GRANOLA_OAUTH_REDIRECT_URI=
# Pre-provisioned client id, to skip Dynamic Client Registration.
GRANOLA_OAUTH_CLIENT_ID=
# Override the MCP discovery base / endpoint (default Granola's hosted server).
GRANOLA_MCP_BASE=
GRANOLA_MCP_URL=
# HMAC secret for inbound Granola webhooks (orthogonal to the OAuth grant).
GRANOLA_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Public-surface security (see the exsto-public-surface skill)
# -----------------------------------------------------------------------------
# REQUIRED for Google OAuth: HMAC key that signs the OAuth state so tenantId /
# returnTo can't be tampered (≥16 chars, random). The OAuth flow fails closed
# without it. Generate: `openssl rand -base64 32`.
OAUTH_STATE_SECRET=
# Optional anti-automation for the public booking form. Set the server secret to
# ENABLE the CAPTCHA gate on public writes (the server verifies `captchaToken`).
# Use exactly one provider. Unset = no-op (the gate waves writes through).
TURNSTILE_SECRET=
HCAPTCHA_SECRET=
# Cloudflare Turnstile PUBLIC site key — the FRONTEND half. The /book form only
# renders the Turnstile widget (and sends `captchaToken`) when this is set.
# Enabling the booking CAPTCHA end-to-end requires BOTH this (frontend) and
# TURNSTILE_SECRET above (server). Unset = no widget; booking submits as today.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Optional rate-limit tuning for the public route (defaults: 20 req / 60s per IP).
PUBLIC_RATE_MAX=
PUBLIC_RATE_WINDOW_MS=

# -----------------------------------------------------------------------------
# Tenant + actor bindings for the @exsto/legal-demo Next.js app
# -----------------------------------------------------------------------------
# Attorney side: ctx now derives from the signed-in session (x-actor-id +
# x-tenant-id headers backed by the actor table). No env vars required.
#
# Client portal: public-intake writes use these defaults until per-tenant
# booking links carry the tenant_id.

LEGAL_CLIENT_TENANT_ID=00000000-0000-0000-0000-000000000001
LEGAL_CLIENT_ACTOR_ID=00000000-0000-0000-0000-000000000004

# -----------------------------------------------------------------------------
# Google Maps Places (booking address autocomplete)
# -----------------------------------------------------------------------------
# Public API key for the /book page address autocomplete. Restrict the key
# in the Google Cloud console to: HTTP referrers = your Netlify domain(s)
# + localhost, APIs = "Places API (New)". The booking flow falls back to a
# plain text input if this is unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Online payments — Stripe Connect (invoice card/ACH payments)
# -----------------------------------------------------------------------------
# exsto-law is the Stripe Connect PLATFORM; each firm onboards as an Express
# CONNECTED ACCOUNT. These are the PLATFORM's keys (not a firm's) — use TEST-mode
# keys (sk_test_… / pk_test_…) until going live. Online payment is off unless both
# the secret and publishable keys are set.
#
#   STRIPE_SECRET_KEY                 platform secret key (server-only)
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY publishable key (browser; embedded Element)
#   STRIPE_WEBHOOK_SECRET            signing secret for /api/webhooks/stripe
#                                    (from `stripe listen` locally, or the Stripe
#                                    dashboard webhook endpoint in prod)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Worker runtime
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3
# Lock-timeout sweep (in the worker/dispatcher): reclaim jobs stranded in
# 'running' by a crash. LOCK_TIMEOUT_SEC must exceed the longest real job so the
# sweep never reclaims one still running (which would double-execute it).
WORKER_SWEEP_INTERVAL_MS=60000
WORKER_LOCK_TIMEOUT_SEC=1800

# -----------------------------------------------------------------------------
# Worker liveness detector — the Netlify SCHEDULED function (runs OFF the worker,
# on Netlify's cron, so a dead worker is still reported). See
# docs/ops/worker-liveness.md and netlify/functions/worker-liveness.mts.
# -----------------------------------------------------------------------------
# Owner / RLS-bypassing Postgres URL. Worker death is cross-tenant, so the
# detector must see ALL tenants' jobs — a non-owner (RLS) URL with no tenant
# context set sees zero rows. Falls back to DATABASE_URL. SET IN NETLIFY.
ALERT_DATABASE_URL=
# Transactional-email alert channel (independent of the worker AND the queue —
# NOT the Gmail adapter). Resend-shaped by default. All three required to send;
# otherwise the detector logs only. SET IN NETLIFY.
#   ALERT_EMAIL_API_KEY   provider API key (e.g. Resend re_…)
#   ALERT_EMAIL_FROM      verified sender address
#   ALERT_EMAIL_TO         recipient(s), comma-separated
#   ALERT_EMAIL_ENDPOINT  optional: override the provider URL (default Resend)
ALERT_EMAIL_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_ENDPOINT=
# Optional threshold overrides for the detector (seconds).
WORKER_LIVENESS_PENDING_THRESHOLD_SEC=600
WORKER_LIVENESS_RUNNING_THRESHOLD_SEC=1800

# -----------------------------------------------------------------------------
# N1 — client-facing transactional email (account confirmation, resend).
# Independent of ALERT_EMAIL_* above (that's internal ops alerts) and of the
# attorney Gmail adapter — this sends AS THE FIRM to a client, so it must work
# even when no attorney is signed in. Resend-shaped by default. Both required
# to send; unconfigured = the confirm-email step logs a warning and no-ops
# (account creation still succeeds — the resend button is the recovery path
# once these are set). SET IN NETLIFY.
#   CLIENT_EMAIL_API_KEY   provider API key (e.g. Resend re_…)
#   CLIENT_EMAIL_FROM      verified sender address on a domain you've verified
#                          in Resend (display name is set dynamically per firm
#                          — e.g. "Pacheco Law <onboarding@notifications.exsto-law.com>")
#   CLIENT_EMAIL_ENDPOINT  optional: override the provider URL (default Resend)
CLIENT_EMAIL_API_KEY=
CLIENT_EMAIL_FROM=
CLIENT_EMAIL_ENDPOINT=
