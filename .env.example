# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored so secrets stay out of version control.

# -----------------------------------------------------------------------------
# Supabase — exsto-law uses the "exsto-law" project (jfcarzprfpoztxuqykoe, us-east-1)
# -----------------------------------------------------------------------------
# Project URL                      → Settings ▸ API ▸ Project URL
SUPABASE_URL=https://jfcarzprfpoztxuqykoe.supabase.co
# Anon public key                  → Settings ▸ API ▸ Project API keys ▸ anon
SUPABASE_ANON_KEY=
# Service role key                 → Settings ▸ API ▸ Project API keys ▸ service_role
SUPABASE_SERVICE_ROLE_KEY=
# Pooler connection string         → Settings ▸ Database ▸ Connection string
#                                   ▸ "Session" or "Transaction" pooler URI
# The password lives only in the dashboard; paste the full URL here with the
# password substituted in.
#
# CRITICAL (ADR 0037): the `postgres` role shown here BYPASSES row-level security.
# Use it ONLY for migrations/seed (pnpm migrate / pnpm seed). Application + worker
# code MUST connect as a NON-owner role (Supabase `authenticated`/`anon` via the
# API, or a dedicated app login role) or tenant isolation is silently inactive.
# Verify with: SUBSTRATE_TEST_DATABASE_URL=... pnpm test:invariants
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Connection used by the invariant test suite (tests/invariants). Point it at a
# DISPOSABLE Supabase project (never production). Without it, the DB-gated
# invariant tests skip. CI sets this from a secret; locally you can reuse a dev URL.
SUBSTRATE_TEST_DATABASE_URL=

# -----------------------------------------------------------------------------
# Anthropic — used by the legal vertical drafting adapter
# PLATFORM DEFAULT only: a key connected in Settings -> Integrations (stored in
# Vault) takes precedence per tenant. Same for GRANOLA_* below. Keys pasted in
# the UI never live in env or in any table column.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Optional: pin the drafting model. Defaults to claude-sonnet-4-6. The
# preflight script uses claude-haiku-4-5-20251001 for its API ping regardless.
LEGAL_DRAFTING_MODEL=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Tenant + actor bindings for the @exsto/legal-demo Next.js app
# -----------------------------------------------------------------------------
# Attorney side: ctx now derives from the signed-in session (x-actor-id +
# x-tenant-id headers backed by the actor table). No env vars required.
#
# Client portal: public-intake writes use these defaults until per-tenant
# booking links carry the tenant_id.

LEGAL_CLIENT_TENANT_ID=00000000-0000-0000-0000-000000000001
LEGAL_CLIENT_ACTOR_ID=00000000-0000-0000-0000-000000000004

# -----------------------------------------------------------------------------
# Google Maps Places (booking address autocomplete)
# -----------------------------------------------------------------------------
# Public API key for the /book page address autocomplete. Restrict the key
# in the Google Cloud console to: HTTP referrers = your Netlify domain(s)
# + localhost, APIs = "Places API (New)". The booking flow falls back to a
# plain text input if this is unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Worker runtime
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3
